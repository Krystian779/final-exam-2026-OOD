<Window x:Class="final_exam_2026.AddNewSession"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:final_exam_2026"
        mc:Ignorable="d"
        Title="AddNewSession" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="20*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*"/>
            <ColumnDefinition Width="70*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Add New Training Session" Margin="10" Grid.ColumnSpan="2" HorizontalAlignment="Center"/>
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            
            <Label Grid.Row="0" Content="Date:" Margin="10"/>
            <Label Grid.Row="1" Content="Start Time:" Margin="10"/>
            <Label Grid.Row="2" Content="Session Type:" Margin="10"/>
            <Label Grid.Row="3" Content="Duration (mins):" Margin="10"/>
            <Label Grid.Row="4" Content="Coach Notes:" Margin="10"/>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="15*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>


            <TextBox x:Name="tbxDate" Grid.Row="0"  Margin="10"/>
            <TextBox x:Name="tbxStartTime" Grid.Row="1"  Margin="10"/>
            <TextBox x:Name="tbxType" Grid.Row="2"  Margin="10"/>
            <TextBox x:Name="tbxDuration" Grid.Row="3"  Margin="10"/>
            <TextBox x:Name="tbxNotes" Grid.Row="4"  Margin="10"/>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" HorizontalAlignment="center" Width="100" Height="50" Margin="10" Click="btnCancel_Click"/>
            <Button Grid.Column="1" Content="Save" HorizontalAlignment="center"  Width="200" Height="50" Margin="10" Click="btnSave_Click"/>

        </Grid>
    </Grid>
</Window>
